# Praevio environment variables.
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# ─── Database (Postgres) ────────────────────────────────────────────────
# Neon recommends a pooled URL for queries and an unpooled URL for migrations.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST_DIRECT/DB?sslmode=require"

# ─── Auth (NextAuth v5) ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="<base64-32-bytes>"
# Set to your production URL when deployed (e.g. https://praevio.fitness)
NEXTAUTH_URL="http://localhost:3000"

# ─── Rate limiting (Upstash Redis) ──────────────────────────────────────
# REQUIRED in production. Without these, brute-force protection on login,
# password reset, invite-accept, and MFA is DISABLED (fails open) and a
# warning is logged on every cold start. Create a free Redis DB at
# https://upstash.com and copy its REST URL + token here.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# Optional: set to "true" to FAIL CLOSED (reject auth requests) if the Upstash
# vars above are missing in production. Only enable once Upstash is provisioned,
# or you will lock yourself out of login.
RATE_LIMIT_STRICT="false"

# ─── Email (Resend) ─────────────────────────────────────────────────────
# Get a key from https://resend.com — sender domain must be verified in Resend.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Praevio <noreply@yourdomain.com>"

# ─── Initial admin user (seeded on db:seed / migrate reset) ─────────────
# - ADMIN_PASSWORD must be at least 12 characters; the seed refuses weaker ones.
# - Generate one with: openssl rand -base64 24
# - Once the admin is seeded and you've logged in, change the password in-app
#   and clear these values from `.env` so they are not lying around.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME="Admin"

# ─── Error tracking (Sentry) ────────────────────────────────────────────
# All Sentry env vars are optional. If NEXT_PUBLIC_SENTRY_DSN is unset,
# the SDK is a no-op and the app runs normally — set it in Vercel to
# start receiving errors.
#
# DSN — found in your Sentry project under Settings → Client Keys (DSN).
# Use NEXT_PUBLIC_ so it's available on the client too.
NEXT_PUBLIC_SENTRY_DSN=""
#
# Source map upload (build-time, optional but recommended in CI/Vercel).
# Without these, errors still arrive but stack traces are minified.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
