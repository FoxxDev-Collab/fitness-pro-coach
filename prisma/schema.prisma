generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  COACH
  CLIENT
}

// ─── Auth Models ────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(COACH)
  active        Boolean   @default(true)
  mfaSecret     String?
  mfaEnabled    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      AuthSession[]

  // Coach relationships
  clients       Client[]   @relation("CoachClients")
  exercises     Exercise[] @relation("CoachExercises")
  programs      Program[]  @relation("CoachPrograms")
  teams         Team[]     @relation("CoachTeams")

  // Client relationship
  clientProfile Client?    @relation("ClientUser")

  // Athlete relationship (portal access)
  athleteProfile Athlete?  @relation("AthleteUser")

  // Coach notes
  coachNotes         ClientNote[]       @relation("CoachNotes")
  teamNotes          TeamNote[]         @relation("CoachTeamNotes")
  athleteNotes       AthleteNote[]      @relation("CoachAthleteNotes")

  // Coach metrics
  metricDefinitions  MetricDefinition[] @relation("CoachMetrics")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique @default(cuid())
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique @default(cuid())
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model InviteToken {
  id        String   @id @default(cuid())
  email     String
  clientId  String
  coachId   String
  token     String   @unique @default(cuid())
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
}

// ─── Domain Models ──────────────────────────────────────────

model Client {
  id               String        @id @default(cuid())
  name             String
  email            String?
  phone            String?
  gender           String?
  goals            String?
  healthConditions String?
  notes            String?
  active           Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  coachId          String?
  coach            User?         @relation("CoachClients", fields: [coachId], references: [id], onDelete: Cascade)

  userId           String?       @unique
  user             User?         @relation("ClientUser", fields: [userId], references: [id])

  assignments      Assignment[]
  measurements     Measurement[]
  clientNotes      ClientNote[]

  @@index([coachId])
}

model Exercise {
  id           String             @id @default(cuid())
  name         String
  category     String             @default("Strength")
  type         String             @default("weight")
  equipment    String?
  muscles      String[]
  instructions String?
  tips         String?
  image        String?
  custom       Boolean            @default(false)
  createdAt    DateTime           @default(now())

  coachId      String?
  coach        User?              @relation("CoachExercises", fields: [coachId], references: [id], onDelete: Cascade)

  workoutExercises WorkoutExercise[]

  @@index([coachId])
}

model Program {
  id          String       @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  coachId     String?
  coach       User?        @relation("CoachPrograms", fields: [coachId], references: [id], onDelete: Cascade)

  workouts        Workout[]
  assignments     Assignment[]
  teamAssignments TeamAssignment[]

  @@index([coachId])
}

model Workout {
  id        String            @id @default(cuid())
  programId String
  name      String
  order     Int               @default(0)
  program   Program           @relation(fields: [programId], references: [id], onDelete: Cascade)
  exercises WorkoutExercise[]

  @@index([programId])
}

model WorkoutExercise {
  id         String   @id @default(cuid())
  workoutId  String
  exerciseId String
  order      Int      @default(0)
  sets       Int      @default(3)
  reps       Int      @default(10)
  weight     Float    @default(0)
  duration   Float    @default(0)
  distance   Float    @default(0)
  rest       Int      @default(60)
  notes      String?
  workout    Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([workoutId])
  @@index([exerciseId])
}

model Assignment {
  id               String              @id @default(cuid())
  clientId         String?
  athleteId        String?
  programId        String
  teamAssignmentId String?
  name             String
  startDate        DateTime?
  assignedAt       DateTime            @default(now())
  client           Client?             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  athlete          Athlete?            @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  program          Program             @relation(fields: [programId], references: [id], onDelete: Cascade)
  teamAssignment   TeamAssignment?     @relation(fields: [teamAssignmentId], references: [id], onDelete: SetNull)
  workouts         AssignmentWorkout[]
  logs             SessionLog[]

  @@index([clientId])
  @@index([athleteId])
  @@index([programId])
  @@index([teamAssignmentId])
}

model AssignmentWorkout {
  id           String                       @id @default(cuid())
  assignmentId String
  name         String
  order        Int                          @default(0)
  assignment   Assignment                   @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  exercises    AssignmentWorkoutExercise[]

  @@index([assignmentId])
}

model AssignmentWorkoutExercise {
  id                  String            @id @default(cuid())
  assignmentWorkoutId String
  exerciseId          String?
  name                String
  type                String            @default("weight")
  category            String            @default("Strength")
  order               Int               @default(0)
  sets                Int               @default(3)
  reps                Int               @default(10)
  weight              Float             @default(0)
  duration            Float             @default(0)
  distance            Float             @default(0)
  rest                Int               @default(60)
  notes               String?
  assignmentWorkout   AssignmentWorkout @relation(fields: [assignmentWorkoutId], references: [id], onDelete: Cascade)

  @@index([assignmentWorkoutId])
}

model SessionLog {
  id           String            @id @default(cuid())
  assignmentId String
  workoutIndex Int
  sessionNotes String?
  duration     Int?
  date         DateTime          @default(now())
  createdAt    DateTime          @default(now())
  assignment   Assignment        @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  exercises    SessionExercise[]

  @@index([assignmentId])
}

model SessionExercise {
  id            String       @id @default(cuid())
  sessionLogId  String
  exerciseIndex Int
  sets          Int?
  reps          Int?
  weight        Float?
  duration      Float?
  distance      Float?
  notes         String?
  sessionLog    SessionLog   @relation(fields: [sessionLogId], references: [id], onDelete: Cascade)
  setDetails    SessionSet[]

  @@index([sessionLogId])
}

model SessionSet {
  id                String          @id @default(cuid())
  sessionExerciseId String
  setNumber         Int
  reps              Int?
  weight            Float?
  duration          Float?
  distance          Float?
  sessionExercise   SessionExercise @relation(fields: [sessionExerciseId], references: [id], onDelete: Cascade)

  @@index([sessionExerciseId])
}

model Measurement {
  id        String   @id @default(cuid())
  clientId  String
  date      DateTime @default(now())
  weight    Float?
  bodyFat   Float?
  chest     Float?
  waist     Float?
  hips      Float?
  arms      Float?
  thighs    Float?
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String
  coachId   String
  content   String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  coach     User     @relation("CoachNotes", fields: [coachId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([coachId])
}

// ─── Team Models ───────────────────────────────────────────

enum EventType {
  PRACTICE
  GAME
  MEETING
  TRYOUT
  CAMP
  FUNDRAISER
  OTHER
}

model Team {
  id              String             @id @default(cuid())
  name            String
  sport           String?
  season          String?
  description     String?
  active          Boolean            @default(true)
  archivedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  coachId         String
  coach           User               @relation("CoachTeams", fields: [coachId], references: [id], onDelete: Cascade)

  athletes        Athlete[]
  teamAssignments TeamAssignment[]
  events          TeamEvent[]
  announcements   TeamAnnouncement[]
  notes           TeamNote[]
  metricEntries   MetricEntry[]      @relation("TeamMetricEntries")

  @@index([coachId])
}

model Athlete {
  id           String       @id @default(cuid())
  name         String
  email        String?
  phone        String?
  gender       String?
  position     String?
  jerseyNumber String?
  notes        String?
  active       Boolean      @default(true)
  parentName   String?
  parentEmail  String?
  parentPhone  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  teamId       String
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  userId       String?      @unique
  user         User?        @relation("AthleteUser", fields: [userId], references: [id])

  assignments    Assignment[]
  athleteNotes   AthleteNote[]
  metricEntries  MetricEntry[]  @relation("AthleteMetricEntries")

  @@index([teamId])
}

model TeamAssignment {
  id          String       @id @default(cuid())
  teamId      String
  programId   String
  name        String
  startDate   DateTime?
  assignedAt  DateTime     @default(now())

  team        Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  program     Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  assignments Assignment[]

  @@index([teamId])
  @@index([programId])
}

model TeamEvent {
  id            String    @id @default(cuid())
  teamId        String
  title         String
  type          EventType @default(PRACTICE)
  description   String?
  location      String?
  opponent      String?
  startTime     DateTime
  endTime       DateTime?
  allDay        Boolean   @default(false)
  notifyParents Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  team          Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  metricEntries MetricEntry[] @relation("EventMetricEntries")

  @@index([teamId])
  @@index([startTime])
}

model TeamAnnouncement {
  id            String   @id @default(cuid())
  teamId        String
  subject       String
  body          String
  notifyParents Boolean  @default(true)
  sentAt        DateTime @default(now())
  createdAt     DateTime @default(now())

  team          Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

// ─── Team & Athlete Notes ──────────────────────────────────

enum NoteCategory {
  GENERAL
  GAME
  PRACTICE
  MEETING
  SCOUTING
}

model TeamNote {
  id        String       @id @default(cuid())
  teamId    String
  coachId   String
  content   String
  pinned    Boolean      @default(false)
  category  NoteCategory @default(GENERAL)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  team      Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  coach     User         @relation("CoachTeamNotes", fields: [coachId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([coachId])
}

model AthleteNote {
  id        String       @id @default(cuid())
  athleteId String
  coachId   String
  content   String
  pinned    Boolean      @default(false)
  category  NoteCategory @default(GENERAL)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  athlete   Athlete      @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  coach     User         @relation("CoachAthleteNotes", fields: [coachId], references: [id], onDelete: Cascade)

  @@index([athleteId])
  @@index([coachId])
}

// ─── Custom Metrics ────────────────────────────────────────

enum MetricScope {
  TEAM
  ATHLETE
}

model MetricDefinition {
  id          String       @id @default(cuid())
  coachId     String
  name        String
  unit        String
  scope       MetricScope
  description String?
  archived    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  coach       User         @relation("CoachMetrics", fields: [coachId], references: [id], onDelete: Cascade)
  entries     MetricEntry[]

  @@index([coachId])
}

model MetricEntry {
  id                   String           @id @default(cuid())
  metricDefinitionId   String
  teamId               String?
  athleteId            String?
  eventId              String?
  value                Float
  notes                String?
  date                 DateTime
  createdAt            DateTime         @default(now())

  metricDefinition     MetricDefinition @relation(fields: [metricDefinitionId], references: [id], onDelete: Cascade)
  team                 Team?            @relation("TeamMetricEntries", fields: [teamId], references: [id], onDelete: Cascade)
  athlete              Athlete?         @relation("AthleteMetricEntries", fields: [athleteId], references: [id], onDelete: Cascade)
  event                TeamEvent?       @relation("EventMetricEntries", fields: [eventId], references: [id], onDelete: SetNull)

  @@index([metricDefinitionId])
  @@index([teamId])
  @@index([athleteId])
  @@index([eventId])
}
